# Copy these values into the repository root .env before running generate_seed_data.py.
# Keep production DB credentials out of this file.

# Database connection for seed loading
SEED_DB_HOST=localhost
SEED_DB_PORT=3306
SEED_DB_NAME=finvibe_test
SEED_DB_USER=finvibe
SEED_DB_PASSWORD=finvibe

# Parallel generation/loading workers
SEED_PARALLEL_WORKERS=8

# User + wallet seed settings
SEED_USER_ROWS=1000
SEED_USER_SOCIAL_RATIO=0.30
SEED_USER_DELETED_RATIO=0.01
SEED_USER_ADMIN_RATIO=0.001

# BCrypt hash used for generated local users
SEED_USER_PASSWORD_HASH=$2a$10$7EqJtq98hPqEX7fNZaFWoO5Y6QnqJ6TP2PzefRg2fzGEylh4G6dkK
