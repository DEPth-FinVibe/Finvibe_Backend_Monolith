{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "uid": "finvibe-app-metrics",
  "title": "Finvibe 애플리케이션 메트릭",
  "description": "1차 관측성 작업으로 추가한 거래, 지갑, 자산, 인증, 뉴스, 스타트업 점검 메트릭 대시보드입니다.",
  "tags": ["finvibe", "application", "prometheus"],
  "timezone": "Asia/Seoul",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "데이터소스",
        "current": {},
        "hide": 0
      },
      {
        "name": "application",
        "type": "query",
        "label": "애플리케이션",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(auth_login_attempts_total, application)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "finvibe-backend-monolith",
          "value": "finvibe-backend-monolith"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "거래",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "생성된 주문 수 (1시간)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(trade_orders_created_total{application=\"$application\"}[1h]))", "legendFormat": "생성" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "체결된 주문 수 (1시간)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(trade_orders_executed_total{application=\"$application\"}[1h]))", "legendFormat": "체결" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "실패한 주문 수 (1시간)",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(trade_orders_failed_total{application=\"$application\"}[1h]))", "legendFormat": "실패" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "예약 주문 평균 체결 시간 (1시간)",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2, "color": { "mode": "thresholds" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(rate(trade_reserved_execution_latency_seconds_sum{application=\"$application\"}[1h])) / sum(rate(trade_reserved_execution_latency_seconds_count{application=\"$application\"}[1h]))", "legendFormat": "평균" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "유형별 거래 처리량",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (order_type, transaction_type) (rate(trade_orders_created_total{application=\"$application\"}[5m]))", "legendFormat": "생성 {{order_type}} {{transaction_type}}" },
        { "expr": "sum by (order_type, transaction_type) (rate(trade_orders_executed_total{application=\"$application\"}[5m]))", "legendFormat": "체결 {{order_type}} {{transaction_type}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "사유별 거래 실패",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (stage, reason) (rate(trade_orders_failed_total{application=\"$application\"}[5m]))", "legendFormat": "{{stage}} / {{reason}}" }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "지갑 및 자산",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "stat",
      "title": "지갑 변동 횟수 (1시간)",
      "gridPos": { "x": 0, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(wallet_balance_mutations_total{application=\"$application\"}[1h]))", "legendFormat": "변동 횟수" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "지갑 변동 금액 합계 (1시간)",
      "gridPos": { "x": 6, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "currencyKRW" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(wallet_balance_mutation_amount_sum{application=\"$application\"}[1h]))", "legendFormat": "금액" }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "수익률 재계산 평균 시간 (15분)",
      "gridPos": { "x": 12, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(rate(asset_profit_recalculation_duration_seconds_sum{application=\"$application\"}[15m])) / sum(rate(asset_profit_recalculation_duration_seconds_count{application=\"$application\"}[15m]))", "legendFormat": "평균" }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "상위 보유 종목 캐시 적중률 (1시간)",
      "gridPos": { "x": 18, "y": 13, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(asset_top_holdings_cache_requests_total{application=\"$application\",result=\"hit\"}[1h])) / clamp_min(sum(increase(asset_top_holdings_cache_requests_total{application=\"$application\"}[1h])), 1)", "legendFormat": "적중률" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "유형별 지갑 변동",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (type) (rate(wallet_balance_mutations_total{application=\"$application\"}[5m]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "수익률 재계산 소요 시간",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(asset_profit_recalculation_duration_seconds_sum{application=\"$application\"}[5m])) / sum(rate(asset_profit_recalculation_duration_seconds_count{application=\"$application\"}[5m]))", "legendFormat": "평균" },
        { "expr": "max(asset_profit_recalculation_duration_seconds_max{application=\"$application\"})", "legendFormat": "최대" }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "인증, 뉴스, 스타트업",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 16,
      "type": "stat",
      "title": "로그인 성공률 (1시간)",
      "gridPos": { "x": 0, "y": 25, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(auth_login_attempts_total{application=\"$application\",result=\"success\"}[1h])) / clamp_min(sum(increase(auth_login_attempts_total{application=\"$application\"}[1h])), 1)", "legendFormat": "성공률" }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "뉴스 AI 평균 분석 시간 (15분)",
      "gridPos": { "x": 8, "y": 25, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(rate(news_ai_analysis_duration_seconds_sum{application=\"$application\"}[15m])) / sum(rate(news_ai_analysis_duration_seconds_count{application=\"$application\"}[15m]))", "legendFormat": "평균" }
      ]
    },
    {
      "id": 18,
      "type": "stat",
      "title": "스타트업 점검 실패 수 (24시간)",
      "gridPos": { "x": 16, "y": 25, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "targets": [
        { "expr": "sum(increase(startup_dependency_checks_total{application=\"$application\",result=\"failure\"}[24h]))", "legendFormat": "실패" }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "결과별 인증 시도",
      "gridPos": { "x": 0, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (method, result) (rate(auth_login_attempts_total{application=\"$application\"}[5m]))", "legendFormat": "{{method}} / {{result}}" }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "뉴스 AI 분석 시간",
      "gridPos": { "x": 8, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (provider) (rate(news_ai_analysis_duration_seconds_sum{application=\"$application\"}[5m])) / sum by (provider) (rate(news_ai_analysis_duration_seconds_count{application=\"$application\"}[5m]))", "legendFormat": "평균 {{provider}}" },
        { "expr": "max by (provider) (news_ai_analysis_duration_seconds_max{application=\"$application\"})", "legendFormat": "최대 {{provider}}" }
      ]
    },
    {
      "id": 21,
      "type": "table",
      "title": "스타트업 의존성 점검 현황",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {} },
      "options": { "showHeader": true },
      "targets": [
        { "format": "table", "instant": true, "expr": "sum by (dependency, result) (startup_dependency_checks_total{application=\"$application\"})", "legendFormat": "{{dependency}} {{result}}" }
      ]
    }
  ]
}
