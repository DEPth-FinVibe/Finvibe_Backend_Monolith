{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "uid": "finvibe-kis-subscription",
  "title": "KIS 업스트림 구독",
  "description": "KIS WebSocket (업스트림) 구독 현황, 용량, 종목 구성, 에러 메트릭",
  "tags": ["finvibe", "kis", "subscription"],
  "timezone": "Asia/Seoul",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "구독 현황",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "세션 수",
      "description": "연결된 업스트림(KIS/Mock) WebSocket 세션 수",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "green", "value": 2 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sessions_available{application=\"finvibe-backend-monolith\"}", "legendFormat": "세션 수" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "구독 종목 수",
      "description": "현재 업스트림에 구독 중인 종목 수 (KisConnectionPool 기준)",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 35 },
            { "color": "red", "value": 40 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_subscriptions_active{application=\"finvibe-backend-monolith\"}", "legendFormat": "구독 종목" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "최대 용량",
      "description": "현재 세션으로 구독 가능한 최대 종목 수 (세션 수 × 41)",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "red", "value": 100 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_subscriptions_capacity{application=\"finvibe-backend-monolith\"}", "legendFormat": "최대 용량" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "노드 구독 (Sync 기준)",
      "description": "KisSubscriptionSynchronizer가 추적하는 이 노드의 구독 수",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 35 },
            { "color": "red", "value": 41 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sync_subscriptions_active{application=\"finvibe-backend-monolith\"}", "legendFormat": "Sync 구독" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "노드 할당 quota",
      "description": "이 노드에 할당된 최대 구독 quota (fair share)",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sync_subscriptions_capacity{application=\"finvibe-backend-monolith\"}", "legendFormat": "quota" }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "용량 대비 사용률",
      "description": "전체 용량(kis_subscriptions_capacity) 대비 실제 구독(kis_subscriptions_active) 비율",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "red", "value": 95 }
          ]},
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_subscriptions_active{application=\"finvibe-backend-monolith\"} / kis_subscriptions_capacity{application=\"finvibe-backend-monolith\"} * 100", "legendFormat": "사용률" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "구독 현황 추이",
      "description": "실제 구독 수, 최대 용량, 노드 할당 quota의 시계열 추이",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_subscriptions_active{application=\"finvibe-backend-monolith\"}", "legendFormat": "구독 (Connection Pool)" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_subscriptions_capacity{application=\"finvibe-backend-monolith\"}", "legendFormat": "최대 용량" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sync_subscriptions_active{application=\"finvibe-backend-monolith\"}", "legendFormat": "구독 (Sync 추적)" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sync_subscriptions_capacity{application=\"finvibe-backend-monolith\"}", "legendFormat": "노드 quota" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "종목 구성 추이",
      "description": "전체 보유 종목, 관심 종목, 예약 종목 수의 시계열",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_stocks_holding{application=\"finvibe-backend-monolith\"}", "legendFormat": "보유 종목" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_stocks_watcher{application=\"finvibe-backend-monolith\"}", "legendFormat": "관심 종목" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_stocks_reservation{application=\"finvibe-backend-monolith\"}", "legendFormat": "예약 종목" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Sync 성능",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "동기화 사이클 실행 시간",
      "description": "KIS 구독 동기화 사이클 1회 실행에 걸리는 시간 (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, rate(kis_sync_execution_seconds_bucket{application=\"finvibe-backend-monolith\"}[1m])) * 1000", "legendFormat": "p50" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, rate(kis_sync_execution_seconds_bucket{application=\"finvibe-backend-monolith\"}[1m])) * 1000", "legendFormat": "p95" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, rate(kis_sync_execution_seconds_bucket{application=\"finvibe-backend-monolith\"}[1m])) * 1000", "legendFormat": "p99" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kis_sync_execution_seconds_sum{application=\"finvibe-backend-monolith\"} / kis_sync_execution_seconds_count{application=\"finvibe-backend-monolith\"} * 1000", "legendFormat": "avg" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "동기화 처리량 (ops/s)",
      "description": "초당 동기화 사이클 실행 횟수 및 에러율",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_sync_execution_seconds_count{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "동기화 처리량" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_sync_errors_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "에러율" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "에러 및 연결",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "에러 이벤트 (rate)",
      "description": "세션 연결 실패, 구독 실패, 락 획득 실패 변화율",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_session_connect_failures_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "세션 연결 실패" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_subscribe_no_session_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "가용 세션 없음" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_sync_errors_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "동기화 에러" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_sync_lock_failures_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "분산 락 실패" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "세션 연결 성공/실패 (rate)",
      "description": "WebSocket 세션 연결 성공 및 실패 변화율",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_session_connect_success_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "연결 성공" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(kis_session_connect_failures_total{application=\"finvibe-backend-monolith\"}[1m])", "legendFormat": "연결 실패" }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "1시간 내 연결 실패",
      "description": "최근 1시간 동안의 세션 연결 실패 누적 건수",
      "gridPos": { "x": 0, "y": 28, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]},
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(kis_session_connect_failures_total{application=\"finvibe-backend-monolith\"}[1h])", "legendFormat": "실패" }
      ]
    }
  ]
}